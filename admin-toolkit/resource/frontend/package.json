{
  "name": "diag-parser",
  "private": true,
  "version": "0.4.205",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "playwright test",
    "test:live:profile": "playwright test tests/live-webapp-timelapse.spec.ts",
    "test:live:timelapse": "playwright test tests/live-webapp-timelapse.spec.ts",
    "test:smoke": "node live-card-smoke.mjs",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css}'",
    "preview": "vite preview"
  },
  "dependencies": {
    "@zip.js/zip.js": "^2.8.16",
    "chart.js": "^4.5.1",
    "chartjs-chart-treemap": "^3.1.0",
    "framer-motion": "^12.30.0",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "pako": "^2.1.0",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-rnd": "^10.5.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.58.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
